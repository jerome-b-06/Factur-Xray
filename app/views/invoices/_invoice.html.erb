<div id="<%= dom_id invoice %>" class="w-full sm:w-auto my-5 space-y-5">
<!--  <div>-->
<!--    <strong class="block font-medium mb-1">Company:</strong>-->
    <%#= invoice.company_id %>
<!--  </div>-->
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= invoice.status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Number:</strong>
    <%= invoice.number %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Issue date:</strong>
    <%= invoice.issue_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Due date:</strong>
    <%= invoice.due_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Total ht:</strong>
    <%= invoice.total_ht %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Total ttc:</strong>
    <%= invoice.total_ttc %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Vat amount:</strong>
    <%= invoice.vat_rate %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Currency:</strong>
    <%= invoice.currency %>
  </div>

  <div>
    <strong class="block font-medium mb-1">Is compliant:</strong>
    <%= invoice.is_compliant? ? "Yes" : "No" %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Audit report:</strong>
    <%= invoice.audit_report %>
  </div>
</div>
