<div id="<%= dom_id invoice %>" class="w-full sm:w-auto my-5 space-y-5">

  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Status:</strong>
    <%= invoice.status %>
  </div>
  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Number:</strong>
    <%= invoice.number %>
  </div>
  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Issue date:</strong>
    <%= invoice.issue_date %>
  </div>
  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Due date:</strong>
    <%= invoice.due_date %>
  </div>

  <table class="table table-zebra">
    <!-- head -->
    <thead>
    <tr>
      <th>Description</th>
      <th>Quantity</th>
      <th>Unit price</th>
      <th>VAT Rate</th>
      <th>Total TTC</th>
    </tr>
    </thead>
    <tbody>
    <% invoice.invoice_items.each do |item| %>
      <tr id="invoice_item_<%= item.id %>">
        <th><%= item.description %></th>
        <td><%= item.quantity %></td>
        <td><%= number_to_currency item.unit_price %></td>
        <td><%= item.vat_rate %> %</td>
        <td><%= number_to_currency item.total_ttc %></td>
      </tr>
    <% end %>
    </tbody>
  </table>


  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Total HT:</strong>
    <%= number_to_currency invoice.total_ht %>
  </div>
  <div class="flex">
    <strong class="block font-medium mb-1 px-3">VAT amount:</strong>
    <%= number_to_currency invoice.total_vat %>
  </div>
  <div class="flex">
    <strong class="block font-medium mb-1 px-3">Total TTC:</strong>
    <%= number_to_currency invoice.total_ttc %>
  </div>
</div>