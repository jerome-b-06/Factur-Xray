<%= form_with(model: [@company, @invoice], class: "contents") do |form| %>
  <% if @invoice.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(@invoice.errors.count, "error") %> prohibited this invoice from being saved:</h2>

      <ul class="list-disc ml-6">
        <% @invoice.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :status %>
    <%= form.select :status,
                    options_for_select(Invoice.statuses.map { |k, v| [v, k] }, @invoice.status),
                    {},
                    class: ["select", { "select-primary": @invoice.errors[:status].none?, "select-error": @invoice.errors[:status].any? }]
    %>
  </div>

  <div class="my-5">
    <%= form.label :number %>
    <%= form.text_field :number, class: ["input", { "input-primary": @invoice.errors[:number].none?, "input-error": @invoice.errors[:number].any? }] %>
  </div>

  <div class="my-5">
    <%= form.label :issue_date %>
    <%= form.date_field :issue_date, class: ["input", { "input-primary": @invoice.errors[:issue_date].none?, "input-error": @invoice.errors[:issue_date].any? }] %>
  </div>

  <div class="my-5">
    <%= form.label :due_date %>
    <%= form.date_field :due_date, class: ["input", { "input-primary": @invoice.errors[:due_date].none?, "input-error": @invoice.errors[:due_date].any? }] %>
  </div>

  <h2>Items</h2>

  <div id="invoice_items">
    <%= form.fields_for :invoice_items do |item_form| %>
      <%= render "invoice_item_fields", item_form: item_form %>
    <% end %>
  </div>

  <% add_item_path = @invoice.persisted? ? add_item_company_invoice_path(@company, @invoice) : add_item_company_invoices_path(@company) %>
  <%= form.submit "Add a new item",
                  formaction: add_item_path,
                  formmethod: :post,
                  data: { turbo_frame: "_top" },
                  class: "btn btn-outline" %>

  <div class="inline">
    <%= form.submit "Save", class: "btn btn-primary" %>
  </div>
<% end %>
