<% content_for :title, "Invoices Validations" %>

<div class="overflow-x-auto">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Invoices Validations</h1>
    <%= link_to "New Validation", new_invoice_validation_path, class: "btn btn-primary" %>
  </div>

  <div id="companies" class=" ">
    <% if @invoice_validations.any? %>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <!-- head -->
          <thead>
          <tr>
            <th>Sender</th>
            <th>invoice N°</th>
            <th>Status</th>
            <th></th>
          </tr>
          </thead>
          <tbody>

          <% @invoice_validations.each do |invoice_validation| %>
            <tr id="invoice_validation_<%= invoice_validation.id %>">
              <th><%= invoice_validation.vendor_name %></th>
              <td><%= invoice_validation.invoice_number %></td>
              <td><%= invoice_validation.status %></td>
              <td>
                <div class="flex items-center justify-center gap-2">
                  <%= link_to invoice_validation, class: "p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition", title: "Show" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  <% end %>

                  <%= link_to invoice_validation, data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?" }, class: "p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition", title: "Supprimer" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>

    <% else %>
      <p class="text-center my-10">No invoice validation found.</p>
    <% end %>
  </div>
</div>
